
u0 = 0.0
v0 = 0.0
Œît = 0.002
Œæ = 0.0
Tn = 0.1
œâ_n = 2*pi/Tn
œâ_D = œâ_n*sqrt(1 - Œæ^2)

#hide
n = 10000
acc = vector(n) + 1
acc = -acc*5
acc = join(acc; vector(4*n))
n = n + 4*n

A = e^(-Œæ*œâ_n*Œît)*((Œæ/sqrt(1 - Œæ^2))*sin(œâ_D*Œît) + cos(œâ_D*Œît))
B = e^(-Œæ*œâ_n*Œît)*(1/œâ_D)*sin(œâ_D*Œît)
C = (1/œâ_n^2)*(2*Œæ/(œâ_n*Œît) + e^(-Œæ*œâ_n*Œît)*(((1 - 2*Œæ^2)/(œâ_D*Œît) - Œæ/sqrt(1 - Œæ^2))*sin(œâ_D*Œît) - (1 + 2*Œæ/(œâ_n*Œît))*cos(œâ_D*Œît)))
D = (1/œâ_n^2)*(1 - 2*Œæ/(œâ_n*Œît) + e^(-Œæ*œâ_n*Œît)*(((2*Œæ^2 - 1)/(œâ_D*Œît))*sin(œâ_D*Œît) + (2*Œæ/(œâ_n*Œît))*cos(œâ_D*Œît)))

A‚Ä≤ = -e^(-Œæ*œâ_n*Œît)*(œâ_n/sqrt(1 - Œæ^2))*sin(œâ_D*Œît)
B‚Ä≤ = e^(-Œæ*œâ_n*Œît)*(cos(œâ_D*Œît) - (Œæ/sqrt(1 - Œæ^2))*sin(œâ_D*Œît))
C‚Ä≤ = (1/(œâ_n^2))*(-1/Œît + e^(-Œæ*œâ_n*Œît)*((œâ_n/sqrt(1 - Œæ^2) + Œæ/(Œît*sqrt(1 - Œæ^2)))*sin(œâ_D*Œît) + (1/Œît)*cos(œâ_D*Œît)))
D‚Ä≤ = (1/(Œît*œâ_n^2))*(1 - e^(-Œæ*œâ_n*Œît)*((Œæ/sqrt(1 - Œæ^2))*sin(œâ_D*Œît) + cos(œâ_D*Œît)))

u = vector(n)
v = vector(n)
a = vector(n)
u.1 = u0
v.1 = v0
a.1 = acc.(1) - 2*Œæ*œâ_n*v.1 - œâ_n^2*u.1
#for i = 1 : n - 1
	u.(i + 1) = A*u.i + B*v.i + C*acc.i + D*acc.(i + 1)
	v.(i + 1) = A‚Ä≤*u.i + B‚Ä≤*v.i + C‚Ä≤*acc.i + D‚Ä≤*acc.(i + 1)
	a.(i + 1) = acc.(i + 1) - 2*Œæ*œâ_n*v.(i + 1) - œâ_n^2*u.(i + 1)
#loop

t = range(0; n - 1; 1)*Œît
#show
$Plot{t.i|u.i @ i = 1 : n}
$Plot{t.i|v.i @ i = 1 : n}
$Plot{t.i|a.i @ i = 1 : n}
$Plot{t.i|-acc.i @ i = 1 : n}

'Max.Disp ='max(abs(u))